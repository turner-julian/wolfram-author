Notebook[{

Cell["Tensor Algebra: Tests & Benchmarks", "Title"],

Cell["Exercises every tensor algebra operation in Core/Tensor/GR \
on the Schwarzschild and AdS spacetimes, verifies correctness against known \
analytic results, and times each operation. Run all cells sequentially.", "Text"],

(* ===================================================================== *)
Cell["Setup", "Section"],

Cell["Load the curated library and define test metrics.", "Text"],

Cell["(* Load via init.wl -- NotebookDirectory[] resolves to examples/ *)\n\
Get[FileNameJoin[{ParentDirectory[NotebookDirectory[]], \"init.wl\"}]]", "Input"],

Cell["$Assumptions = M > 0 && r > 2 M && L > 0 && z > 0 && 0 < \[Theta] < Pi;", "Input"],

Cell["(* --- Schwarzschild metric --- *)\n\
schwCoords = {t, r, \[Theta], \[Phi]};\n\
schwF = 1 - 2 M/r;\n\
schwGdown = DiagonalMatrix[{-schwF, 1/schwF, r^2, r^2 Sin[\[Theta]]^2}];\n\
gSchw = Tensor`Field[schwCoords, {\"down\", \"down\"}, schwGdown, Automatic,\n\
   <|\"spacetime\" -> \"Schwarzschild\"|>];\n\
\n\
(* --- AdS4 Poincare metric --- *)\n\
adsCoords = {t, x, y, z};\n\
adsGdown = (L^2/z^2) DiagonalMatrix[{-1, 1, 1, 1}];\n\
gAdS = Tensor`Field[adsCoords, {\"down\", \"down\"}, adsGdown, Automatic,\n\
   <|\"spacetime\" -> \"AdS4\"|>];\n\
\n\
Print[\"Metrics defined.\"]", "Input"],

Cell["(* Precompute curvature tensors *)\n\
Core`CacheClear[];\n\
schwRiem = GR`Riemann[gSchw];\n\
schwRicci = GR`Ricci[gSchw];\n\
schwRicciScalar = GR`RicciScalar[gSchw];\n\
adsRiem = GR`Riemann[gAdS];\n\
adsRicci = GR`Ricci[gAdS];\n\
Column[{\n\
  Row[{\"Schwarzschild R = \", schwRicciScalar}],\n\
  Row[{\"AdS4 R = \", GR`RicciScalar[gAdS]}]\n\
}]", "Input"],

(* ===================================================================== *)
Cell["1. Index Raising & Lowering", "Section"],

Cell["Raise the first index of the Schwarzschild all-lower Riemann tensor, \
then lower it back. The round-trip must recover the original components.", "Text"],

Cell["(* Raise first index: R_{rho sigma mu nu} -> R^rho_{sigma mu nu} *)\n\
schwRiemUp = Tensor`Raise[schwRiem, 1, gSchw];\n\
\n\
(* Round-trip: lower it back *)\n\
schwRiemRT = Tensor`Lower[schwRiemUp, 1, gSchw];\n\
Column[{\n\
  Row[{\"Original indices: \", Tensor`Indices[schwRiem]}],\n\
  Row[{\"Raised indices:   \", Tensor`Indices[schwRiemUp]}],\n\
  Row[{\"Round-trip correct: \",\n\
    Core`EquivalentQ[Tensor`Components[schwRiemRT],\n\
      Tensor`Components[schwRiem]]}]\n\
}]", "Input"],

Cell["(* AdS4: the mixed Ricci R^mu_nu should be -(D-1)/L^2 delta^mu_nu *)\n\
(* For D=4: R^mu_nu = -3/L^2 delta^mu_nu *)\n\
adsRicciUp = Tensor`Raise[adsRicci, 1, gAdS];\n\
Tensor`Components[adsRicciUp] // MatrixForm", "Input"],

Cell["Column[{\n\
  HoldForm[Subsuperscript[R, \[Nu], \[Mu]] == -(3/Superscript[L, 2]) Subscript[\[DoubleStruckCapitalI], 4]],\n\
  Core`EquivalentQ[Tensor`Components[adsRicciUp],\n\
    -3/L^2 IdentityMatrix[4]]\n\
}]", "Input"],

Cell["(* Timing *)\n\
tRaise = First@RepeatedTiming[Tensor`Raise[schwRiem, 1, gSchw]];\n\
tLower = First@RepeatedTiming[Tensor`Lower[schwRiemUp, 1, gSchw]];\n\
Print[\"Raise (Schwarzschild Riemann): \", 1000 tRaise, \" ms\"];\n\
Print[\"Lower (round-trip):          \", 1000 tLower, \" ms\"]", "Input"],

(* ===================================================================== *)
Cell["2. Trace (Contraction of Two Indices)", "Section"],

Cell["Contract R^m_{sigma m nu} (indices 1 and 3) to recover the Ricci tensor.", "Text"],

Cell["ricciFromTrace = Tensor`Trc[schwRiemUp, {1, 3}];\n\
Column[{\n\
  Row[{\"Trace \", HoldForm[Subsuperscript[R, Row[{\"\[Sigma]\", \"m\", \"\[Nu]\"}], \"m\"]], \" == Ricci: \",\n\
    Core`EquivalentQ[Tensor`Components[ricciFromTrace],\n\
      Tensor`Components[schwRicci]]}],\n\
  Row[{\"Result indices: \", Tensor`Indices[ricciFromTrace]}]\n\
}]", "Input"],

Cell["Trace the mixed AdS Ricci R^mu_mu to get the Ricci scalar.", "Text"],

Cell["ricciScalarFromTrace = Tensor`Trc[adsRicciUp, {1, 2}];\n\
ricciScalarDirect = GR`RicciScalar[gAdS];\n\
Column[{\n\
  Row[{\"Trace \", HoldForm[Subsuperscript[R, \"\[Mu]\", \"\[Mu]\"]], \" = \", ricciScalarFromTrace}],\n\
  Row[{\"Direct R = \", ricciScalarDirect}],\n\
  Row[{\"Agree: \", Core`EquivalentQ[ricciScalarFromTrace, ricciScalarDirect]}]\n\
}]", "Input"],

Cell["(* Timing *)\n\
tTrace = First@RepeatedTiming[Tensor`Trc[schwRiemUp, {1, 3}]];\n\
Print[\"Trace (Riemann -> Ricci): \", 1000 tTrace, \" ms\"]", "Input"],

(* ===================================================================== *)
Cell["3. Tensor Product & Contract", "Section"],

Cell["Outer product of two vectors, then contract to get a scalar.", "Text"],

Cell["(* A timelike unit vector and its covector *)\n\
vUp = Tensor`Field[schwCoords, {\"up\"}, {1, 0, 0, 0}, schwGdown, <||>];\n\
wDown = Tensor`Field[schwCoords, {\"down\"}, {-schwF, 0, 0, 0}, schwGdown, <||>];\n\
\n\
(* Outer product: rank-2 mixed tensor *)\n\
vw = Tensor`Prod[vUp, wDown];\n\
Column[{\n\
  Row[{\"Product rank: \", Tensor`Rank[vw]}],\n\
  Row[{\"Product indices: \", Tensor`Indices[vw]}],\n\
  Tensor`Components[vw] // MatrixForm\n\
}]", "Input"],

Cell["(* Trace the product: v^mu w_mu *)\n\
scalar = Tensor`Trc[vw, {1, 2}];\n\
\n\
(* Contract does the same in one call *)\n\
scalarDirect = Tensor`Contract[vUp, 1, wDown, 1];\n\
Column[{\n\
  Row[{HoldForm[Superscript[v, \"\[Mu]\"] Subscript[w, \"\[Mu]\"]], \" = \", scalar}],\n\
  Row[{\"Contract agrees: \", Core`EquivalentQ[scalar, scalarDirect]}]\n\
}]", "Input"],

(* ===================================================================== *)
Cell["4. Coordinate Transformation", "Section"],

Cell["Transform the Schwarzschild metric to ingoing Eddington-Finkelstein \
coordinates. The backward map is t = v - r - 2M Log[r/(2M) - 1].", "Text"],

Cell["efCoords = {v, r, \[Theta], \[Phi]};\n\
efRules = {t -> v - r - 2 M Log[r/(2 M) - 1]};\n\
\n\
gEF = Tensor`Transform[gSchw, efCoords, efRules];\n\
Tensor`Components[gEF] // MatrixForm", "Input"],

Cell["(* Known EF metric: ds^2 = -(1-2M/r) dv^2 + 2 dv dr + r^2 dOmega^2 *)\n\
gEFexpected = {\n\
  {-(1 - 2 M/r), 1, 0, 0},\n\
  {1, 0, 0, 0},\n\
  {0, 0, r^2, 0},\n\
  {0, 0, 0, r^2 Sin[\[Theta]]^2}};\n\
\n\
Row[{\"Matches known EF metric: \",\n\
  Core`EquivalentQ[Tensor`Components[gEF], gEFexpected]}]", "Input"],

Cell["Transform a 2D flat metric from Cartesian to polar coordinates.", "Text"],

Cell["gFlat2 = Tensor`Field[{xx, yy}, {\"down\", \"down\"},\n\
  IdentityMatrix[2], Automatic, <||>];\n\
gPolar = Tensor`Transform[gFlat2, {rr, \[Psi]},\n\
  {xx -> rr Cos[\[Psi]], yy -> rr Sin[\[Psi]]}];\n\
\n\
Column[{\n\
  Tensor`Components[gPolar] // MatrixForm,\n\
  Row[{\"== diag(1, \", HoldForm[Superscript[r, 2]], \"): \",\n\
    Core`EquivalentQ[Tensor`Components[gPolar],\n\
      DiagonalMatrix[{1, rr^2}]]}]\n\
}]", "Input"],

Cell["(* Timing *)\n\
tTransform = First@RepeatedTiming[\n\
  Tensor`Transform[gSchw, efCoords, efRules]];\n\
Print[\"Transform Schwarzschild -> EF: \", 1000 tTransform, \" ms\"]", "Input"],

(* ===================================================================== *)
Cell["5. Covariant Derivative", "Section"],

Cell["Schwarzschild is vacuum: R_{mu nu} = 0, so the covariant derivative \
of the Ricci tensor must vanish identically.", "Text"],

Cell["nablaRicci = GR`CovariantD[schwRicci, gSchw];\n\
Column[{\n\
  Row[{\"Indices of \", HoldForm[Subscript[\"\[Del]\", \"\[Alpha]\"] Subscript[R, Row[{\"\[Mu]\", \"\[Nu]\"}]]], \": \", Tensor`Indices[nablaRicci]}],\n\
  Row[{HoldForm[Subscript[\"\[Del]\", \"\[Alpha]\"] Subscript[R, Row[{\"\[Mu]\", \"\[Nu]\"}]]], \" == 0 (vacuum): \",\n\
    Core`EquivalentQ[Tensor`Components[nablaRicci],\n\
      ConstantArray[0, {4, 4, 4}]]}]\n\
}]", "Input"],

Cell["Covariant derivative of a scalar field phi = L^2/z^2 on AdS4. \
For a scalar, this is just the partial derivative (gradient).", "Text"],

Cell["phi = Tensor`Field[adsCoords, {}, L^2/z^2, adsGdown, <||>];\n\
dPhi = GR`CovariantD[phi, gAdS];\n\
\n\
Column[{\n\
  Row[{\"\[Del]\[Phi] components: \", Tensor`Components[dPhi]}],\n\
  Row[{HoldForm[Subscript[\"\[PartialD]\", z] \"\[Phi]\"], \" = \", Tensor`Components[dPhi][[4]]}],\n\
  Row[{\"Correct: \",\n\
    Core`EquivalentQ[Tensor`Components[dPhi][[4]], -2 L^2/z^3]}]\n\
}]", "Input"],

Cell["Covariant derivative of a vector field on AdS4. Here the Gamma \
corrections are nontrivial.", "Text"],

Cell["(* Take the covariant derivative of the coordinate basis vector d/dz *)\n\
eZ = Tensor`Field[adsCoords, {\"up\"}, {0, 0, 0, 1}, adsGdown, <||>];\n\
nablaEZ = GR`CovariantD[eZ, gAdS];\n\
Column[{\n\
  Row[{HoldForm[Subscript[\"\[Del]\", \"\[Mu]\"] \"(\[PartialD]/\[PartialD]z)\"], \" indices: \", Tensor`Indices[nablaEZ]}],\n\
  Tensor`Components[nablaEZ] // MatrixForm\n\
}]", "Input"],

Cell["(* Timing *)\n\
tCovD = First@RepeatedTiming[\n\
  GR`CovariantD[schwRicci, gSchw]];\n\
Print[\"Covariant derivative of Ricci: \", 1000 tCovD, \" ms\"]", "Input"],

(* ===================================================================== *)
Cell["6. Geodesic Equations", "Section"],

Cell["Schwarzschild geodesics: 4 second-order ODEs.", "Text"],

Cell["geod = GR`Geodesic[gSchw, \[Lambda]];\n\
Column[\n\
  Prepend[\n\
    Table[Column[{Style[schwCoords[[i]], Bold], Row[{geod[[i]], \" = 0\"}]}], {i, 4}],\n\
    Row[{\"Geodesic equations: \", Length[geod]}]\n\
  ], Spacings -> 1]", "Input"],

Cell["The t-equation should give conservation of energy: \
d/dlambda[(1-2M/r) dt/dlambda] = 0, which expands to \
(1-2M/r) t'' + (2M/r^2) r' t' = 0.", "Text"],

Cell["(* Timing *)\n\
tGeod = First@RepeatedTiming[\n\
  GR`Geodesic[gSchw, \[Lambda]]];\n\
Print[\"Geodesic equations: \", 1000 tGeod, \" ms\"]", "Input"],

(* ===================================================================== *)
Cell["7. Caching: Cold vs Warm Pipeline", "Section"],

Cell["Clear the cache, run the full pipeline (Christoffel -> Riemann -> \
Ricci -> covariant derivative), then run it again to measure the speedup \
from cached Christoffel symbols.", "Text"],

Cell["Core`CacheClear[];\n\
\n\
tCold = First@AbsoluteTiming[\n\
  Module[{ch, ri, rc, cd},\n\
    ch = GR`Christoffel[gSchw];\n\
    ri = GR`Riemann[gSchw];\n\
    rc = GR`Ricci[gSchw];\n\
    cd = GR`CovariantD[rc, gSchw];\n\
    \"done\"]];\n\
\n\
tWarm = First@AbsoluteTiming[\n\
  Module[{ch, ri, rc, cd},\n\
    ch = GR`Christoffel[gSchw];\n\
    ri = GR`Riemann[gSchw];\n\
    rc = GR`Ricci[gSchw];\n\
    cd = GR`CovariantD[rc, gSchw];\n\
    \"done\"]];\n\
\n\
Column[{\n\
  Row[{\"Cold (no cache): \", 1000 tCold, \" ms\"}],\n\
  Row[{\"Warm (cached):   \", 1000 tWarm, \" ms\"}],\n\
  Row[{\"Speedup:         \", tCold/tWarm, \"x\"}]\n\
}]", "Input"],

(* ===================================================================== *)
Cell["8. Summary", "Section"],

Cell["Column[{\n\
  Style[\"TIMING SUMMARY (Schwarzschild, D=4)\", Bold],\n\
  Grid[{\n\
    {\"Raise index\", Row[{1000 tRaise, \" ms\"}]},\n\
    {\"Lower index\", Row[{1000 tLower, \" ms\"}]},\n\
    {\"Trace\", Row[{1000 tTrace, \" ms\"}]},\n\
    {\"Coord transform\", Row[{1000 tTransform, \" ms\"}]},\n\
    {\"Covariant deriv\", Row[{1000 tCovD, \" ms\"}]},\n\
    {\"Geodesic eqs\", Row[{1000 tGeod, \" ms\"}]},\n\
    {\"Cache cold/warm\", Row[{1000 tCold, \"/\", 1000 tWarm, \" ms  (\", tCold/tWarm, \"x)\"}]}\n\
  }, Alignment -> Left, Spacings -> {2, 0.5}]\n\
}]", "Input"]

},
WindowSize -> {900, 800},
WindowMargins -> {{Automatic, Automatic}, {Automatic, Automatic}},
FrontEndVersion -> "14.0",
StyleDefinitions -> "Default.nb",
DefaultNewCellStyle -> "Input",
DefaultOutputFormatType -> TraditionalForm
]
