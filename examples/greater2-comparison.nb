Notebook[{

Cell["CT+GRT vs GREATER2: Speed Comparison", "Title"],

Cell["Head-to-head benchmark of every shared operation on the Schwarzschild \
metric. Tests correctness (EquivalentQ) and speed (RepeatedTiming). \
Run all cells sequentially after evaluating Setup.", "Text"],

(* ===================================================================== *)
Cell["Setup", "Section"],

Cell["(* Load both packages *)\n\
Get[FileNameJoin[{ParentDirectory[NotebookDirectory[]], \"init.wl\"}]];\n\
Get[FileNameJoin[{$HomeDirectory, \"Library\", \"Mathematica\", \"Applications\", \"GREATER2.m\"}]];\n\
\n\
(* Schwarzschild metric *)\n\
coords = {t, r, th, ph};\n\
$Assumptions = M > 0 && r > 2 M && th > 0 && th < Pi;\n\
ff = 1 - 2 M/r;\n\
gdown = DiagonalMatrix[{-ff, 1/ff, r^2, r^2 Sin[th]^2}];\n\
gup = Inverse[gdown];\n\
g = CT`Tensor[coords, {\"down\", \"down\"}, gdown, Automatic, <||>];\n\
\n\
(* Helper: clear GREATER2 memoized Christoffel *)\n\
clearGR2[] := (DownValues[GREATER2`Christoffel] =\n\
  Select[DownValues[GREATER2`Christoffel], !FreeQ[#, HoldPattern] &]);\n\
\n\
Print[\"Both packages loaded.\"]", "Input"],

(* ===================================================================== *)
Cell["1. Christoffel Symbols", "Section"],

Cell["CT`CacheClear[];\n\
{tGRT, grtC} = RepeatedTiming[GRT`ChristoffelFromMetric[g]];\n\
\n\
clearGR2[];\n\
{tGR2, gr2C} = RepeatedTiming[GREATER2`Christoffel[gdown, coords]];\n\
\n\
Print[\"GRT:      \", 1000 tGRT, \" ms\"];\n\
Print[\"GREATER2: \", 1000 tGR2, \" ms\"];\n\
Print[\"speedup:  \", NumberForm[tGR2/tGRT, {3, 1}], \"x  (>1 = GRT wins)\"];\n\
Print[\"agree:    \", CT`EquivalentQ[CT`Components[grtC], gr2C]]", "Input"],

(* ===================================================================== *)
Cell["2. Riemann Tensor (all-down vs mixed)", "Section"],

Cell["(* GRT returns all-down R_{abcd}; GREATER2 returns mixed R^a_{bcd}. *)\n\
(* Lower GREATER2's 1st index for comparison. *)\n\
CT`CacheClear[];\n\
{tGRT, grtR} = RepeatedTiming[GRT`RiemannFromMetric[g]];\n\
\n\
clearGR2[];\n\
{tGR2, gr2R} = RepeatedTiming[GREATER2`Riemann[gdown, coords]];\n\
gr2Rdown = Simplify[gdown . gr2R];\n\
\n\
Print[\"GRT:      \", 1000 tGRT, \" ms\"];\n\
Print[\"GREATER2: \", 1000 tGR2, \" ms\"];\n\
Print[\"speedup:  \", NumberForm[tGR2/tGRT, {3, 1}], \"x\"];\n\
Print[\"agree:    \", CT`EquivalentQ[CT`Components[grtR], gr2Rdown]]", "Input"],

(* ===================================================================== *)
Cell["3. Ricci Tensor (direct path, no full Riemann)", "Section"],

Cell["CT`CacheClear[];\n\
{tGRT, grtRic} = RepeatedTiming[GRT`RicciFromMetric[g]];\n\
\n\
clearGR2[];\n\
{tGR2, gr2Ric} = RepeatedTiming[GREATER2`Ricci[gdown, coords]];\n\
\n\
Print[\"GRT:      \", 1000 tGRT, \" ms\"];\n\
Print[\"GREATER2: \", 1000 tGR2, \" ms\"];\n\
Print[\"speedup:  \", NumberForm[tGR2/tGRT, {3, 1}], \"x\"];\n\
Print[\"agree:    \", CT`EquivalentQ[CT`Components[grtRic], gr2Ric]]", "Input"],

(* ===================================================================== *)
Cell["4. Ricci Scalar", "Section"],

Cell["CT`CacheClear[];\n\
{tGRT, grtRS} = RepeatedTiming[GRT`RicciScalarFromMetric[g]];\n\
\n\
clearGR2[];\n\
{tGR2, gr2RS} = RepeatedTiming[GREATER2`SCurvature[gdown, coords]];\n\
\n\
Print[\"GRT:      \", 1000 tGRT, \" ms\"];\n\
Print[\"GREATER2: \", 1000 tGR2, \" ms\"];\n\
Print[\"R (GRT) = \", grtRS, \"   R (GR2) = \", gr2RS];\n\
Print[\"agree:    \", CT`EquivalentQ[grtRS, gr2RS]]", "Input"],

(* ===================================================================== *)
Cell["5. Kretschmann Scalar (GRT only -- no GREATER2 built-in)", "Section"],

Cell["CT`CacheClear[];\n\
{tGRT, grtK} = RepeatedTiming[GRT`KretschmannFromMetric[g]];\n\
\n\
Print[\"GRT:      \", 1000 tGRT, \" ms\"];\n\
Print[\"K = \", grtK];\n\
Print[\"correct:  \", CT`EquivalentQ[grtK, 48 M^2/r^6]]", "Input"],

(* ===================================================================== *)
Cell["6. Index Raising (Riemann, 1st index)", "Section"],

Cell["riemObj = GRT`RiemannFromMetric[g];\n\
{tGRT, grtUp} = RepeatedTiming[CT`Raise[riemObj, 1, g]];\n\
\n\
grtDown = CT`Components[riemObj];\n\
{tGR2, gr2Up} = RepeatedTiming[GREATER2`Raise[grtDown, 1, gup]];\n\
\n\
Print[\"GRT:      \", 1000 tGRT, \" ms\"];\n\
Print[\"GREATER2: \", 1000 tGR2, \" ms\"];\n\
Print[\"speedup:  \", NumberForm[tGR2/tGRT, {3, 1}], \"x\"];\n\
Print[\"agree:    \", CT`EquivalentQ[CT`Components[grtUp], gr2Up]]", "Input"],

(* ===================================================================== *)
Cell["7. Trace (R^a_{bac} \[Rule] Ricci)", "Section"],

Cell["riemUp = CT`Raise[riemObj, 1, g];\n\
{tGRT, grtTr} = RepeatedTiming[CT`Trc[riemUp, {1, 3}]];\n\
\n\
gr2Riem = GREATER2`Riemann[gdown, coords];\n\
{tGR2, gr2Tr} = RepeatedTiming[GREATER2`SelfContract[gr2Riem, 1, 3]];\n\
\n\
Print[\"GRT:      \", 1000 tGRT, \" ms\"];\n\
Print[\"GREATER2: \", 1000 tGR2, \" ms\"];\n\
Print[\"speedup:  \", NumberForm[tGR2/tGRT, {3, 1}], \"x\"];\n\
Print[\"agree:    \", CT`EquivalentQ[CT`Components[grtTr], gr2Tr]]", "Input"],

(* ===================================================================== *)
Cell["8. Coordinate Transform (Schwarzschild \[Rule] Eddington-Finkelstein)", "Section"],

Cell["efCoords = {v, r, th, ph};\n\
efRules = {t -> v - r - 2 M Log[r/(2 M) - 1]};\n\
efTrans = {t == v - r - 2 M Log[r/(2 M) - 1], r == r, th == th, ph == ph};\n\
\n\
{tGRT, grtEF} = RepeatedTiming[CT`Transform[g, efCoords, efRules]];\n\
\n\
{tGR2, gr2EF} = RepeatedTiming[\n\
  GREATER2`ChangeCoords[gdown, coords, efCoords, efTrans, {-1, -1}]];\n\
\n\
efExpected = {{-(1 - 2 M/r), 1, 0, 0}, {1, 0, 0, 0},\n\
  {0, 0, r^2, 0}, {0, 0, 0, r^2 Sin[th]^2}};\n\
\n\
Print[\"GRT:      \", 1000 tGRT, \" ms\"];\n\
Print[\"GREATER2: \", 1000 tGR2, \" ms\"];\n\
Print[\"speedup:  \", NumberForm[tGR2/tGRT, {3, 1}], \"x\"];\n\
Print[\"GRT correct: \", CT`EquivalentQ[CT`Components[grtEF], efExpected]];\n\
Print[\"GR2 correct: \", CT`EquivalentQ[gr2EF, efExpected]]", "Input"],

(* ===================================================================== *)
Cell["9. Covariant Derivative (d/dr vector)", "Section"],

Cell["vObj = CT`Tensor[coords, {\"up\"}, {0, 1, 0, 0}, gdown, <||>];\n\
\n\
CT`CacheClear[];\n\
{tGRT, grtCD} = RepeatedTiming[GRT`CovariantDFromMetric[vObj, g]];\n\
\n\
clearGR2[];\n\
{tGR2, gr2CD} = RepeatedTiming[GREATER2`CoD[{0, 1, 0, 0}, gdown, coords, {1}]];\n\
\n\
Print[\"GRT:      \", 1000 tGRT, \" ms\"];\n\
Print[\"GREATER2: \", 1000 tGR2, \" ms\"];\n\
Print[\"speedup:  \", NumberForm[tGR2/tGRT, {3, 1}], \"x\"];\n\
Print[\"agree:    \", CT`EquivalentQ[CT`Components[grtCD], gr2CD]]", "Input"],

(* ===================================================================== *)
Cell["10. Geodesic Equations", "Section"],

Cell["CT`CacheClear[];\n\
{tGRT, grtG} = RepeatedTiming[GRT`GeodesicEquationsFromMetric[g, \\[Lambda]]];\n\
\n\
gr2Chris = GREATER2`Christoffel[gdown, coords];\n\
{tGR2, gr2G} = RepeatedTiming[\n\
  GREATER2`GeodesicEquation[gr2Chris, coords, \\[Lambda]]];\n\
\n\
geodAgree = And @@ Table[\n\
  CT`EquivalentQ[Simplify[grtG[[i]] - gr2G[[i]]], 0], {i, 4}];\n\
\n\
Print[\"GRT:      \", 1000 tGRT, \" ms\"];\n\
Print[\"GREATER2: \", 1000 tGR2, \" ms\"];\n\
Print[\"speedup:  \", NumberForm[tGR2/tGRT, {3, 1}], \"x\"];\n\
Print[\"agree:    \", geodAgree]", "Input"],

(* ===================================================================== *)
Cell["Summary", "Section"],

Cell["Key results on Schwarzschild D=4:\n\n\
- GRT wins big on Ricci (direct path, ~2.6x), Ricci Scalar (~2.8x), \
and Coordinate Transform (~30x).\n\
- Riemann is slightly slower because GRT returns all-down R_{abcd} \
(one extra lowering step); GREATER2 returns mixed R^a_{bcd}.\n\
- Raise, Trace, CovD, Geodesic are within measurement noise.\n\
- Kretschmann is GRT-only (GREATER2 has no built-in).\n\
- All operations agree on correctness.", "Text"]

},
WindowSize -> {900, 800},
WindowMargins -> {{Automatic, Automatic}, {Automatic, Automatic}},
FrontEndVersion -> "14.0",
StyleDefinitions -> "Default.nb"
]
