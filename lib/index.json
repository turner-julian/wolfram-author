      "signature": "Lower[t_?TensQ, n_Integer] or Lower[t, n, g]",
      "summary": "Lower index n. Same Dot-based engine as Raise.",
      "benchmark": {
        "date": "2026-05-28",
        "problem": "Schwarzschild Riemann, lower 1st index (round-trip)",
        "candidates": [{"id": "builtin-dot", "seconds": 0.000242}],
        "winner": "builtin-dot"
      },
      "equivalence": {"verified": true, "method": "round-trip Raise then Lower == original"}
    },
    {
      "name": "Trc",
      "file": "CT.wl",
      "context": "CT`",
      "signature": "Trc[t_?TensQ, {i_Integer, j_Integer}]",
      "summary": "Contract (trace) indices i and j. One must be up, one down. Uses TensorContract.",
      "benchmark": {
        "date": "2026-05-28",
        "problem": "Schwarzschild R^m_{sigma m nu} -> Ricci",
        "candidates": [{"id": "builtin-tensorcontract", "seconds": 0.000535}],
        "winner": "builtin-tensorcontract"
      },
      "equivalence": {"verified": true, "method": "Trc[R^m_smn, {1,3}] == RicciFromMetric"}
    },
    {
      "name": "Prod",
      "file": "CT.wl",
      "context": "CT`",
      "signature": "Prod[t1_?TensQ, t2_?TensQ]",
      "summary": "Tensor (outer) product. Rank r1+r2. Uses Outer[Times, ...]."
    },
    {
      "name": "Contract",
      "file": "CT.wl",
      "context": "CT`",
      "signature": "Contract[t1_?TensQ, i_Integer, t2_?TensQ, j_Integer]",
      "summary": "Contract index i of t1 with j of t2. Shorthand for Trc[Prod[...], ...]."
    },
    {
      "name": "Transform",
      "file": "CT.wl",
      "context": "CT`",
      "signature": "Transform[t_?TensQ, newCoords_List, rules_List]",
      "summary": "Coordinate transformation. rules = backward map. Jacobian contractions via Dot.",
      "benchmark": {
        "date": "2026-05-28",
        "problem": "Schwarzschild -> Eddington-Finkelstein",
        "candidates": [{"id": "builtin-dot", "seconds": 0.000120}],
        "winner": "builtin-dot"
      },
      "equivalence": {"verified": true, "method": "EquivalentQ vs known analytic EF metric"}
    },
    {
      "name": "CovariantDFromMetric",
      "file": "GRT.wl",
      "context": "GRT`",
      "signature": "CovariantDFromMetric[t_?TensQ, g_?TensQ]",
      "summary": "Covariant derivative. Prepends one down index. Partial + Gamma corrections via Dot. Cached Christoffels.",
