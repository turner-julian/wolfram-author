    {
      "name": "ChristoffelFromMetric",
      "file": "GRT.wl",
      "context": "GRT`",
      "signature": "ChristoffelFromMetric[g_?TensQ]",
      "summary": "Christoffel symbols Gamma^a_bc, as a Tensor {up,down,down}. Cached.",
      "representation": "input metric Tensor {down,down}; output Tensor {up,down,down}",
      "conventions": {"christoffel": "Levi-Civita: Gamma^a_bc = 1/2 g^as (d_b g_sc + d_c g_sb - d_s g_bc)"},
      "depends_on": ["CT"],
      "benchmark": {
        "date": "2026-05-28",
        "problem": "AdS4 Poincare",
        "method": "RepeatedTiming",
        "candidates": [
          {"id": "builtin-array", "seconds": 0.00176},
          {"id": "ogre", "seconds": 0.01837}
        ],
        "winner": "builtin-array"
      },
      "equivalence": {"verified": true, "method": "EquivalentQ", "reference": "builtin-array", "against": ["ogre"]}
    },
