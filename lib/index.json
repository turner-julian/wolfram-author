      "context": "CT`",
      "signature": "Raise[t_?TensQ, n_Integer] or Raise[t, n, g]",
      "summary": "Raise index n. Dot-based contraction (Transpose + Dot + Transpose back). Inverse metric cached.",
      "benchmark": {
        "date": "2026-05-28",
        "problem": "Schwarzschild Riemann, raise 1st index",
        "candidates": [{"id": "builtin-dot", "seconds": 0.000379}],
